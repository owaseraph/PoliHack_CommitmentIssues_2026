{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "3.0",
  "description": "Real-time phishing and scam detection for every page you visit.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://polihackcommitmentissues2026-production.up.railway.app/*",
    "https://polihackcommitmentissues2026-production-019d.up.railway.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "PhishGuard" },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "https://polihackcommitmentissues2026-production.up.railway.app/*",
        "https://polihackcommitmentissues2026-production-019d.up.railway.app/*",
        "https://accounts.google.com/*",
        "https://oauth2.googleapis.com/*",
        "https://apis.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}